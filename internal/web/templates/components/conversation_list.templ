package components

import (
	"fmt"
	"knowledge_base_RAG/internal/domain"
)

templ ConversationList(items []domain.Conversation, activeConversationID string, activeKBID string) {
	<section class="workspace-panel">
		<h2>Conversations</h2>
		if activeKBID == "" {
			<p class="muted">Choose a knowledge base first.</p>
		} else if len(items) == 0 {
			<p class="muted">No conversations yet for this knowledge base.</p>
		} else {
			<div class="list-stack">
				for _, item := range items {
					<a
						href={ templ.SafeURL("/?kb=" + activeKBID + "&conversation=" + item.ID) }
						class={ "list-item", templ.KV("active", item.ID == activeConversationID) }
					>
						<div class="list-title">{ item.Title }</div>
						<div class="list-meta">{ fmt.Sprintf("Updated %s", item.UpdatedAt.Format("Jan 2, 2006 3:04 PM")) }</div>
					</a>
				}
			</div>
		}
	</section>
}
